# Backend configuration. Copy to backend/.env for local dev (gitignored).
# Every integration is a no-op until its vars are set, so the bare minimum to
# boot is DATABASE_URL.

# Postgres (required). The local `nix run .#db` cluster is trust-auth (no
# password); point at your own cluster's URL otherwise.
DATABASE_URL=postgres://postgres@localhost:5432/ev_landing
# HTTP listen address (optional, default 0.0.0.0:8080)
BIND_ADDR=0.0.0.0:8080
SITE_URL=https://evinvest.vn
APP_ENV=development

# Email — Gmail SMTP. Unset ⇒ emails are logged, not delivered.
# For Gmail use an App Password (not the account password) with 2FA enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=EV Investment <careers@evinvest.vn>
MAIL_TEAM=careers@evinvest.vn

# Error monitoring — Sentry. Unset ⇒ no-op.
SENTRY_DSN=

# Product analytics — PostHog (server-side capture). Unset ⇒ no-op.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
