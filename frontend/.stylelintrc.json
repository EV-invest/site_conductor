{
  "plugins": ["stylelint-value-no-unknown-custom-properties"],
  "rules": {
    "csstools/value-no-unknown-custom-properties": [
      true,
      {
        "importFrom": [
          {
            "customProperties": {
              "--font-inter": "Inter, sans-serif",
              "--font-playfair": "Playfair Display, serif"
            }
          }
        ]
      }
    ]
  }
}
