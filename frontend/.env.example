# Public (client-exposed) env vars — all must be prefixed NEXT_PUBLIC_.

# Canonical production origin (https, NO trailing slash, pick www-or-not once).
# Drives metadataBase, canonical URLs, robots host, sitemap URLs, the OG image
# base, and every JSON-LD @id. Without it the build falls back to the obvious
# placeholder https://evinvest.example — set this before going live.
NEXT_PUBLIC_SITE_URL=https://evinvest.example

# Backend API origin consumed by the generated client (shared/api).
# Paths already carry /api/v1, so this is just the origin. Defaults to the
# local backend (cargo run) when unset.
NEXT_PUBLIC_API_URL=http://localhost:58844
# Server-only override for Server Component fetches (e.g. an internal/cluster
# address). NOT exposed to the browser. Falls back to NEXT_PUBLIC_API_URL.
API_URL_INTERNAL=

# OAuth portal (investor login URL is built at runtime)
NEXT_PUBLIC_OAUTH_PORTAL_URL=
NEXT_PUBLIC_APP_ID=

# Cabinet zone (multi-zone mount — see PATTERNS.md §9). CABINET_ZONE_URL
# (server-only) is the cabinet deployment's origin; when set, next.config
# rewrites /cabinet/* to it. Set NEXT_PUBLIC_CABINET_PATH=/cabinet alongside so
# the header CTA hard-links into the zone (cross-zone nav = full document load).
# Dev: nix run .#cabinet in ../banking serves it on http://localhost:3000.
CABINET_ZONE_URL=
NEXT_PUBLIC_CABINET_PATH=

# Google Maps via the Forge proxy (src/shared/ui/map.tsx)
NEXT_PUBLIC_FRONTEND_FORGE_API_KEY=
NEXT_PUBLIC_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Umami analytics (loaded in app/layout.tsx when both are set)
NEXT_PUBLIC_ANALYTICS_ENDPOINT=
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=

# Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (public DSN is safe to share).
# SENTRY_AUTH_TOKEN is only needed in CI for source map uploads — never in .env.local.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development
SENTRY_DSN=
# Server/edge environment tag (sentry.server.config.ts / sentry.edge.config.ts).
APP_ENV=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
