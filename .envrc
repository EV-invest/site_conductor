use flake
# rust-lld (wasm32 linker) needs libLLVM.dylib which lives in the rustc sysroot lib/,
# not in the bin/../lib/ rpath embedded in the binary. Required on macOS with Nix.
# Use the FALLBACK var, not DYLD_LIBRARY_PATH: the latter is searched *before* a
# binary's own rpath and so forces Nix's clang onto rustc's older libLLVM when
# linking host proc-macros (missing LLVM-21 symbols → abort). The fallback is only
# consulted when normal resolution fails — exactly rust-lld's case, never clang's.
export DYLD_FALLBACK_LIBRARY_PATH="$(rustc --print sysroot)/lib${DYLD_FALLBACK_LIBRARY_PATH:+:$DYLD_FALLBACK_LIBRARY_PATH}"
